{
  "manifest_version": 3,
  "name": "PoB PoE2 Trade Helper",
  "version": "0.1.0",
  "description": "Path of Building integration for the PoE2 trade site. This product isn't affiliated with or endorsed by Grinding Gear Games in any way.",

  "permissions": ["storage", "sidePanel", "activeTab"],
  "host_permissions": [
    "https://www.pathofexile.com/*",
    "https://*/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],

  "background": {
    "service_worker": "dist/background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": [
        "https://www.pathofexile.com/trade2/*",
        "https://www.pathofexile.com/trade/*"
      ],
      "js": ["dist/content.js"],
      "css": ["dist/content.css"],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["dist/page-script.js"],
      "matches": [
        "https://www.pathofexile.com/trade2/*",
        "https://www.pathofexile.com/trade/*"
      ]
    }
  ],

  "side_panel": {
    "default_path": "panel.html"
  },

  "action": {
    "default_title": "PoB Trade Helper",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
